<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="CSS\opties.css">
    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/x-icon" href="/img/Cat_World_Icon.ico">
    <title>Cat World - Opties</title>
</head>
<body>

    <%- include('partials/header') %>

    <main class="options-container">
        <h1>Instellingen & Opties</h1>
        <p class="subtitle">Pas jouw Cat World ervaring aan naar eigen wens.</p>

        <div class="options-card">
            
            <div class="option-row">
                <div class="option-info">
                    <h3>Weergave (Dark Mode)</h3>
                    <p>Wissel tussen de lichte (oranje/wit) en de donkere weergave.</p>
                </div>
                <div class="option-control">
                    <label class="switch">
                        <input type="checkbox" id="dark-mode-toggle" onchange="toggleDarkMode()">
                        <span class="slider round"></span>
                    </label>
                </div>
            </div>

            <hr class="divider">

            <div class="option-row">
                <div class="option-info">
                    <h3>Taal / Language</h3>
                    <p>Verander de taal van de knoppen en menu's (de feitjes-API blijft Engels).</p>
                </div>
                <div class="option-control">
                    <select id="language-select" onchange="changeLanguage()">
                        <option value="nl">Nederlands 🇳🇱</option>
                        <option value="en">English 🇬🇧</option>
                    </select>
                </div>
            </div>

            <hr class="divider">

            <div class="option-row">
                <div class="option-info">
                    <h3>Fabrieksinstellingen</h3>
                    <p>Wis alle opgeslagen voorkeuren en zet de website terug naar de basis.</p>
                </div>
                <div class="option-control">
                    <button class="reset-btn" onclick="resetSettings()">Reset Instellingen</button>
                </div>
            </div>

        </div>
    </main>

    <%- include('partials/footer') %>

    <script>
        // --- INITIALISATIE ---
        window.addEventListener('DOMContentLoaded', () => {
            // Dark Mode status ophalen en checkbox synchroniseren
            const isDarkMode = localStorage.getItem('darkMode') === 'enabled';
            document.getElementById('dark-mode-toggle').checked = isDarkMode;
            if (isDarkMode) document.body.classList.add('dark-theme');

            // Taalvoorkeur ophalen en UI direct vertalen
            const savedLang = localStorage.getItem('siteLanguage') || 'nl';
            document.getElementById('language-select').value = savedLang;
            applyLanguageStrings(savedLang);
        });

        // --- DARK MODE LOGICA ---
        function toggleDarkMode() {
            const checkbox = document.getElementById('dark-mode-toggle');
            if (checkbox.checked) {
                document.body.classList.add('dark-theme');
                localStorage.setItem('darkMode', 'enabled');
            } else {
                document.body.classList.remove('dark-theme');
                localStorage.setItem('darkMode', 'disabled');
            }
        }

        // --- TAAL LOGICA ---
        function changeLanguage() {
            const selectedLang = document.getElementById('language-select').value;
            localStorage.setItem('siteLanguage', selectedLang);
            applyLanguageStrings(selectedLang);
        }

        // Update alle tekst-elementen op de pagina naar de geselecteerde taal
        function applyLanguageStrings(lang) {
            const title = document.querySelector('h1');
            const subtitle = document.querySelector('.subtitle');
            const headers = document.querySelectorAll('.option-info h3');
            const paragraphs = document.querySelectorAll('.option-info p');
            const resetBtn = document.querySelector('.reset-btn');
            
            if (lang === 'en') {
                title.textContent = "Settings & Options";
                subtitle.textContent = "Customize your Cat World experience to your liking.";
                headers[0].textContent = "Display (Dark Mode)";
                paragraphs[0].textContent = "Toggle between the light (orange/white) and dark display.";
                headers[1].textContent = "Language / Taal";
                paragraphs[1].textContent = "Change the language of buttons and menus (API data remains English).";
                headers[2].textContent = "Factory Reset";
                paragraphs[2].textContent = "Clear all saved preferences and restore the website to default.";
                resetBtn.textContent = "Reset Settings";
            } else {
                title.textContent = "Instellingen & Opties";
                subtitle.textContent = "Pas jouw Cat World ervaring aan naar eigen wens.";
                headers[0].textContent = "Weergave (Dark Mode)";
                paragraphs[0].textContent = "Wissel tussen de lichte (oranje/wit) en de donkere weergave.";
                headers[1].textContent = "Taal / Language";
                paragraphs[1].textContent = "Verander de taal van de knoppen en menu's (de feitjes-API blijft Engels).";
                headers[2].textContent = "Fabrieksinstellingen";
                paragraphs[2].textContent = "Wis alle opgeslagen voorkeuren en zet de website terug naar de basis.";
                resetBtn.textContent = "Reset Instellingen";
            }
        }

        // --- RESET LOGICA ---
        // Verwijdert alle opgeslagen data en ververst de pagina
        function resetSettings() {
            if (confirm("Weet je zeker dat je alle instellingen wilt resetten?")) {
                localStorage.clear();
                location.reload();
            }
        }
    </script>
</body>
</html>