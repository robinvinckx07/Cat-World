<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="CSS/header_footer.css">
    <title>Footer</title>
  </head>
  <body>
    <footer class="main-footer">
        <div class="footer-container">
            <p id="footer-text">&copy; Gemaakt door Robin Vinckx 🐾</p>
        </div>
    </footer>

    <script>
    // Wacht tot de pagina geladen is.
    window.addEventListener('DOMContentLoaded', () => {
        const savedLang = localStorage.getItem('siteLanguage') || 'nl';
        const footerP = document.getElementById('footer-text');
        const installBtn = document.getElementById('pwa-install-btn');
        
        // Pas teksten aan voor Engels.
        if (savedLang === 'en') {
            if (footerP) {
                footerP.innerHTML = "&copy; Made by Robin Vinckx 🐾";
            }
            if (installBtn) {
                installBtn.textContent = "Install App";
            }
        }
    });
    </script>

    <script>
      // Registreer de Service Worker.
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js')
            .then((reg) => console.log('SW: Succesvol geregistreerd!', reg.scope))
            .catch((err) => console.error('SW: Registratie mislukt:', err));
        });
      }

      // Variabele voor het installatievenster.
      let deInstallatiePrompt;

      // Zoek de installatieknop.
      const installatieKnop = document.getElementById('pwa-install-btn');

      // Wacht tot de app installeerbaar is.
      window.addEventListener('beforeinstallprompt', (event) => {

        // Voorkom de standaard melding.
        event.preventDefault();

        // Bewaar het installatie-event.
        deInstallatiePrompt = event;
        
        // Toon de installatieknop.
        if (installatieKnop) {
          installatieKnop.style.display = 'inline-block';
        }
      });

      // Klik op de installatieknop.
      if (installatieKnop) {
        installatieKnop.addEventListener('click', async () => {

          // Stop als installeren niet mogelijk is.
          if (!deInstallatiePrompt) return;
          
          // Toon het installatievenster.
          deInstallatiePrompt.prompt();
          
          // Wacht op de keuze van de gebruiker.
          const { outcome } = await deInstallatiePrompt.userChoice;

          console.log(`Gebruiker koos voor: ${outcome}`);
          
          // Wis het event en verberg de knop.
          deInstallatiePrompt = null;
          installatieKnop.style.display = 'none';
        });
      }

      // Verberg de knop na installatie.
      window.addEventListener('appinstalled', () => {
        console.log('App is succesvol geïnstalleerd!');

        if (installatieKnop) {
          installatieKnop.style.display = 'none';
        }
      });
    </script>
  </body>
</html>